# ── IAOS Backend configuration ───────────────────────────────
# Copy to .env and fill in. NEVER commit .env.

# MySQL connection
DATABASE_URL=mysql+pymysql://iaos:your_password@localhost:3306/iaos

# JWT signing — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440    
ALGORITHM=HS256

# CORS — comma separated origins for the React app
CORS_ORIGINS=http://localhost:5173

# Bootstrap super admin (created on first startup if no super admin exists)
SUPERADMIN_EMAIL=admin@capcorp.com
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_NAME=Cap Corp Administrator

# App
ENV=development
